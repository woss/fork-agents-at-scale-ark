{
  "name": "ark-broker",
  "version": "0.1.65",
  "description": "Ark broker for memory, telemetry streaming, and observability",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "NODE_ENV=development tsx watch --clear-screen=false src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src test --ext .ts",
    "lint:fix": "eslint src test --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "(cd ../../.. && husky services/ark-broker/ark-broker/.husky) || true"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --check",
      "eslint --max-warnings 0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.9",
    "protobufjs": "^8.6.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@faker-js/faker": "^10.4.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.8.0",
    "@types/supertest": "^7.2.0",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "selfsigned": "^5.5.0",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.1",
    "tmp": "^0.2.7",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "picomatch": "^4.0.4",
    "qs": "^6.15.2",
    "swagger-jsdoc": {
      "glob": "^7.2.3"
    },
    "flatted": "^3.4.2",
    "tar": "^7.5.11",
    "express-rate-limit": "^8.3.0",
    "brace-expansion": ">=5.0.6",
    "esbuild": "^0.28.1",
    "ws": "^8.21.0",
    "form-data": "^4.0.6",
    "undici": "^7.28.0"
  }
}
