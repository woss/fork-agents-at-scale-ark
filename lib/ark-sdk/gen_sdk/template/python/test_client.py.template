    # ApiException Propagation Tests - Issue #2373
    # These tests ensure Kubernetes ApiException is propagated with status codes intact,
    # allowing SDK consumers to distinguish 404 (not found) from 403 (RBAC) from 5xx (cluster issues)

    def test_get_resource_404_propagates_apiexception(self):
        """Test that 404 errors propagate as ApiException with status=404"""
        from kubernetes.client.rest import ApiException

        # Setup: Mock API raises 404
        self.mock_api_client.get_namespaced_custom_object.side_effect = ApiException(status=404, reason="Not Found")
        client = ARKResourceClient(
            api_version="test.io/v1",
            kind="TestResource",
            plural="testresources",
            model_class=MockModel,
            namespace="default"
        )

        # Verify: ApiException propagates with status intact
        with self.assertRaises(ApiException) as ctx:
            client.get("missing-resource")

        self.assertEqual(ctx.exception.status, 404)

