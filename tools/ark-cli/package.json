{
  "name": "@agents-at-scale/ark",
  "version": "0.1.66-rc.1",
  "description": "Ark CLI - Interactive terminal interface for ARK agents",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "ark": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    ".arkrc.template.yaml"
  ],
  "scripts": {
    "build": "npm run copy-templates && tsc && chmod +x dist/index.js",
    "copy-templates": "rm -rf templates && cp -r ../../templates .",
    "dev": "tsc --watch",
    "start": "NODE_NO_WARNINGS=1 node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/ --fix && prettier --write src/",
    "lint:check": "eslint src/ && prettier --check src/",
    "test": "vitest run --coverage",
    "postinstall": "echo \"Ark CLI installed. Run 'ark' to try it out.\""
  },
  "keywords": [
    "ark",
    "cli",
    "terminal",
    "ai",
    "agents"
  ],
  "license": "Apache-2.0",
  "author": "McKinsey & Company",
  "repository": {
    "type": "git",
    "url": "https://github.com/mckinsey/agents-at-scale-ark.git",
    "directory": "tools/ark-cli"
  },
  "homepage": "https://github.com/mckinsey/agents-at-scale-ark#readme",
  "bugs": {
    "url": "https://github.com/mckinsey/agents-at-scale-ark/issues"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.16.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "debug": "^4.4.1",
    "execa": "^9.6.0",
    "find-process": "^1.4.7",
    "ink": "^6.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^12.1.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "open": "^10.2.0",
    "ora": "^8.2.0",
    "picomatch": "4.0.4",
    "react": "^19.1.5",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/debug": "^4.1.12",
    "@types/inquirer": "^9.0.7",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.13",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.0.0",
    "globals": "^16.2.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "brace-expansion": ">=5.0.7",
    "minimatch": "^10.2.3",
    "rollup": "4.59.0",
    "hono": "^4.12.25",
    "@hono/node-server": "^1.19.13",
    "flatted": "^3.4.2",
    "tar": "^7.5.11",
    "express-rate-limit": "^8.3.0",
    "fast-uri": "^3.1.3",
    "ws": "^8.21.0",
    "esbuild": "^0.28.1",
    "form-data": "^4.0.6"
  }
}
